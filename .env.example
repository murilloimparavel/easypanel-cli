# easypanel-cli — environment variables
# Copy this file to .env and fill in your values.
# These variables override the active context from ~/.config/easypanel/config.json.

# EasyPanel instance URL (required)
EASYPANEL_URL=https://panel.example.com

# API token (preferred over email/password)
# Generate one in the EasyPanel UI under Settings > API
EASYPANEL_TOKEN=your_api_token_here
